  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon -w src --ext ts --exec ts-node src/index.ts",
    "watch": "ts-node-dev --respawn --inspect --debug --ignore-watch node_modules src/index.ts",
    "typeorm": "node --require ts-node/register ./node_modules/typeorm/cli.js",
    "db:migrate": "ts-node -r dotenv/config node_modules/typeorm/cli.js migration:run --",
    "db:create": "ts-node -r dotenv/config node_modules/typeorm/cli.js migration:create -- -n",
    "db:generate": "ts-node -r dotenv/config node_modules/typeorm/cli.js migration:generate -n",
    "db:rollback": "ts-node -r dotenv/config node_modules/typeorm/cli.js migration:revert --",
    "db:purge": "ts-node -r dotenv/config node_modules/typeorm/cli.js schema:drop --",
    "build": "rimraf dist && tsc --build && cp .env ./dist/ && cp app.config.js ./dist",
    "remoteA": "ssh -t -i \"key/yauhingtech-lightsail.pem\" bitnami@46.137.207.18 \"cd git/kts_todo_list/ ; bash\"",
    "updateA": "ssh -t -i \"key/yauhingtech-lightsail.pem\" bitnami@46.137.207.18 \"cd git/kts_todo_list/ ; yarn run update_todo_server; exit; bash\"",
    "remoteDev": "ssh -t -i \"key/yauhingtech-lightsail.pem\" bitnami@46.137.207.18 \"cd git/todo_dev/ ; bash\"",
    "updateDev": "ssh -t -i \"key/yauhingtech-lightsail.pem\" bitnami@46.137.207.18 \"cd git/todo_dev/ ; yarn run update_todo_server_dev; exit; bash\"",
    "update_todo_server": "git pull && npm i && yarn run build && pm2 reload todo",
    "update_todo_server_dev": "git pull && npm i && yarn run build && pm2 reload todo_dev",
    "rebind": "pm2 delete todo_server && pm2 start app.config.js",
    "seed": "ts-node -r dotenv/config src/db/seed.ts",
    "tunnel": "node key/tunnel.js"
  },
